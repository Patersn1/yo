<!DOCTYPE html>
<html>
  <head>
    <title>SERVD</title>
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Roboto:100" rel="stylesheet">
    <%= csrf_meta_tags %>
  </head>
  <body>
    <a id="jump-to-content" href="#main_content_block" tabindex="1">
      Jump to content
    </a>
    <ul class="nav">
      <li id="homeContainer" class="nav-hover">
        <%= link_to root_path do %>
          <%= image_tag "servd-logo.gif", :class => "homebutton" %>
        <% end %>
      </li>
      <% if user_signed_in? %>
        <li class="nav-hover"> <%= link_to "Events", opportunities_path %></li>
        <li class="nav-hover"> <%= link_to "Pending", pending_path %></li>
        <li class="nav-hover"> <%= link_to "Organizations", organizations_path %></li>
        <li class="nav-hover"> <%= link_to "Dashboard", dashboard_path_url %></li>
        <li class="nav-hover"> <%= link_to "Notifications", notifications_path %></li>
        <% if current_user.admin %>
        <li class="nav-hover"> <%= link_to "Volunteers", search_path %></li>
        <% end %>
        <% if current_user.admin %>
        <li class="nav-hover"> <%= link_to "Approval", approval_path %></li>
        <% end %>
        <% if current_user.admin %>
          <li class="nav-hover"><%= link_to "Manage Interests", "/add_tags"  %></li>
        <% end %>
        <div class="farRight nav-hover">
          Account

          <div class="hover-dropdown-items">
            <!-- Added link to profile page from the account button -->
            <li class="profile nav-hover"><%= link_to "Profile", profile_page_path %></li>
            <li class="logout nav-hover"><%= link_to "Logout", destroy_user_session_path, method: :delete, data: { turbo_method: :delete } %></li>
          </div>
        </div>
      <% end %>
    </ul>
    <p class="notice" align="center"><%= notice %></p>
    <p class="alert" align="center"><%= alert %></p>

    <div id="main_content_block">
      <%= yield %>
    </div>
    <!-- <div id="foots"></div> -->
    <%= javascript_include_tag "turbo", "data-turbo-track": "reload", defer: true %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </body>
</html>
