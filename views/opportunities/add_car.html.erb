
<h2 style="text-align:center">Add Car for <%= @opportunity_name%></h2>

<h2 style="text-align:center">Add Car</h2>
<br>
<p style="text-align:center">Thank you for volunteering to drive to the event!
</p>

<%= form_with url: "/search", method: :get do |form| %>
  <%= form.label :number_field, "How many people would you be able to drive" %>
  <br>
  <%= form.text_field :number_field %>
  <%= form.submit "Submit" %>
<% end %>

<br>

<div style="text-align: center;">
  <div class="styledButton">
    <%= link_to 'Back', roster_path %>
  </div>
</div>
