<h1><center>New Opportunity</center></h1>
<div style="text-align: center;">
  <div style="display: inline-block; text-align: left;">
    <% if current_user.admin then %>
      <%= render 'form', opportunity: @opportunity %>
    <% else %>
      <h1>You must be lost. You don't have access to this page.</h1>
    <% end %>
    <div class="styledButton">
      <center><%= link_to 'Back', :back %></center>
    </div>
  </div>
</div>
